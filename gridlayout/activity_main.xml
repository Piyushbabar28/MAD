<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:columnCount="2"
    android:rowCount="2"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/top_left_textview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_rowWeight="1"
        android:layout_columnWeight="1"
        android:layout_margin="32dp"
        android:background="#DFDFDF"
        android:gravity="center"
        android:text="RETURN" />

    <TextView
        android:id="@+id/top_right_textview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_rowWeight="1"
        android:layout_columnWeight="1"
        android:layout_margin="32dp"
        android:background="#DFDFDF"
        android:gravity="center"
        android:text="@string/top_right" />

    <TextView
        android:id="@+id/bottom_left_textview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_rowWeight="1"
        android:layout_columnWeight="1"
        android:layout_margin="32dp"
        android:background="#DFDFDF"
        android:gravity="center"
        android:text="@string/bottom_left" />

    <TextView
        android:id="@+id/bottom_right_textview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_rowWeight="1"
        android:layout_columnWeight="1"
        android:layout_margin="32dp"
        android:background="#DFDFDF"
        android:gravity="center"
        android:text="@string/bottom_right" />

</GridLayout>
